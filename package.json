		"@rollup/plugin-node-resolve": "^11.2.1",
		"@rollup/plugin-typescript": "^8.2.1",
		"@types/node": "^14.14.37",
		"@typescript-eslint/eslint-plugin": "^5.5.0",
		"obsidian": "^1.12.3",
		"rollup": "^2.32.1",
		"tslib": "^2.2.0",
		"typescript": "^4.2.4"
	}
